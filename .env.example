# ========================================
# Folio — .env (used by docker-compose only; native runs read application-local.yml instead)
# ========================================
# Copy this file to .env and fill in real values.
# Anything you don't set here uses the default shown above each line.
#
# IMPORTANT: docker compose's .env parser does NOT support inline comments.
# Comments must be on their own line. NEVER write `KEY=value # comment`
# — the `# comment` portion gets parsed as part of the value and breaks things.
# ========================================


# ---------- Required (compose refuses to start without these) ----------
GEMINI_API_KEY=
PEXELS_API_KEY=


# ---------- Cloudflare R2 (image upload silently fails without these) ----------
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=
# Format: https://pub-<hash>.r2.dev or your custom domain
R2_PUBLIC_URL=


# ---------- Optional overrides (defaults are fine for personal use) ----------
# Strong password is critical for production. Generate with: openssl rand -hex 16
# Default: 123456
# MYSQL_ROOT_PASSWORD=

# Default: folio
# MYSQL_DATABASE=

# Default: empty (no auth — fine when Redis is on docker network only)
# REDIS_PASSWORD=

# Default: 8123 (host port for the backend; bound to 127.0.0.1 only)
# BACKEND_PORT=

# Default: 8080 (host port for the frontend; bound to 127.0.0.1 only — Caddy/nginx fronts it)
# FRONTEND_PORT=

# Default: gemini-2.5-flash
# GEMINI_TEXT_MODEL=

# Default: gemini-2.5-flash-image
# GEMINI_IMAGE_MODEL=

# Default: Europe/Amsterdam
# TZ=


# ---------- Stripe (only needed if you turn on VIP payments) ----------
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_SUCCESS_URL=http://localhost/vip?success=true
# STRIPE_CANCEL_URL=http://localhost/vip?cancelled=true
