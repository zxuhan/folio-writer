# ========================================
# Folio — .env (used by docker-compose only; native runs read application-local.yml instead)
# ========================================
# Copy this file to .env and fill in real values.
# Anything you don't set here uses the default shown in the comment.
# ========================================

# ---------- Required (compose refuses to start without these) ----------
GEMINI_API_KEY=
PEXELS_API_KEY=

# ---------- Cloudflare R2 (image upload silently fails without these) ----------
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=
R2_PUBLIC_URL=                  # https://pub-<hash>.r2.dev or your custom domain

# ---------- Optional overrides (defaults are fine for personal use) ----------
# MYSQL_ROOT_PASSWORD=123456    # default: 123456
# MYSQL_DATABASE=folio          # default: folio
# REDIS_PASSWORD=               # default: empty (no auth)
# BACKEND_PORT=8123             # default: 8123 (host port for the backend)
# FRONTEND_PORT=80              # default: 80
# GEMINI_TEXT_MODEL=gemini-2.5-flash         # default: gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image  # default: gemini-2.5-flash-image
# TZ=Europe/Amsterdam     # default: Europe/Amsterdam

# ---------- Stripe (only needed if you turn on VIP payments) ----------
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_SUCCESS_URL=http://localhost/vip?success=true
# STRIPE_CANCEL_URL=http://localhost/vip?cancelled=true
